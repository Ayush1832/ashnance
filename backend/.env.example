# ============================================================
# Ashnance Backend — Environment Variables
# ============================================================

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ashnance?schema=public"

# JWT Secrets
JWT_SECRET="your-jwt-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Solana
# For devnet testing:  SOLANA_RPC_URL="https://api.devnet.solana.com"
# For mainnet:         SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_PRIVATE_KEY=""

# Master keypair used to derive unique deposit addresses for each user.
# Format: JSON array of 64 numbers (Uint8Array serialized)
# Generate: solana-keygen new --outfile master-keypair.json
# Read key: node -e "const k=require('./master-keypair.json');console.log(JSON.stringify(k))"
MASTER_KEYPAIR_SECRET=""

# Email (SendGrid / SMTP)
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="your-sendgrid-api-key"
EMAIL_FROM="noreply@ashnance.io"

# OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Frontend URL (CORS)
FRONTEND_URL="http://localhost:3000"

# Redis (for WebSocket + caching)
REDIS_URL="redis://localhost:6379"

# AI (OpenAI / Gemini)
AI_API_KEY=""
