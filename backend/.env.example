# ============================================================
# Ashnance Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ashnance?schema=public"

# JWT Secrets
JWT_SECRET="your-jwt-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Solana
# For devnet testing:  SOLANA_RPC_URL="https://api.devnet.solana.com"
# For mainnet:         SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_PRIVATE_KEY=""

# Master keypair used to derive unique deposit addresses for each user.
# Format: JSON array of 64 numbers (Uint8Array serialized)
# Generate: solana-keygen new --outfile master-keypair.json
# Read key: node -e "const k=require('./master-keypair.json');console.log(JSON.stringify(k))"
MASTER_KEYPAIR_SECRET=""

# Solana USDC Mint Address
# Devnet:  Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr
# Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDC_MINT="Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr"

# Email (Gmail SMTP / SendGrid)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="your-email@gmail.com"

# OAuth (Google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Frontend / Backend URLs
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:4000"

# Redis (for WebSocket + caching)
REDIS_URL="redis://localhost:6379"

# Owner panel — comma-separated list of admin email addresses
# These users get access to the /owner page on the frontend
OWNER_EMAILS="admin@yourdomain.com"

# Owner withdrawal wallet addresses (Solana public keys)
OWNER_1_WALLET=""
OWNER_2_WALLET=""

# AI (OpenAI / Gemini — optional)
AI_API_KEY=""
